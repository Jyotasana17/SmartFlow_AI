SMARTFLOW_ENV=development
SMARTFLOW_API_HOST=0.0.0.0
SMARTFLOW_API_PORT=8000
SMARTFLOW_JWT_SECRET=change-me-in-production
SMARTFLOW_JWT_ISSUER=smartflow-ai
SMARTFLOW_ACCESS_TOKEN_MINUTES=30
SMARTFLOW_REFRESH_TOKEN_DAYS=7
SMARTFLOW_POSTGRES_DSN=postgresql+asyncpg://smartflow:smartflow@postgres:5432/smartflow
SMARTFLOW_REDIS_URL=redis://redis:6379/0
SMARTFLOW_MONGO_URI=mongodb://mongo:27017
SMARTFLOW_MONGO_DB=smartflow
SMARTFLOW_EVENT_BUS=memory
SMARTFLOW_YOLO_MODEL=yolov8n.pt
SMARTFLOW_ENABLE_REAL_MODEL=false
SMARTFLOW_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
